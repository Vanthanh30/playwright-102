{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@data/*": ["data/*"],
      "@locators/*": ["locators/*"],
      "@models/*": ["models/*"],
      "@pages/*": ["pages/*"],
      "@translations/*": ["translations/*"],
      "@utilities/*": ["utilities/*"]
    },
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "playwright.config.ts",
    "data/**/*.ts",
    "locators/**/*.ts",
    "models/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "translations/**/*.ts",
    "utilities/**/*.ts"
  ]
}
